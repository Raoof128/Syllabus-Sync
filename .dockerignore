# Docker Environment Configuration

# Ignore files for Docker build context
.git
.gitignore
.dockerignore
node_modules
README.md
Dockerfile*
docker-compose*
.dockerignore

# Development artifacts
.next
coverage
.nyc_output
logs

# IDE files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Documentation
docs/
*.md
!docker/README.md

# Configuration files
.env*
.env.local
.env.production

# Test files
test-results/
playwright-report/
test-results.xml

# Temporary files
*.tmp
*.temp
.cache

# Build artifacts that shouldn't be in production build
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database files (handled by volumes)
*.sqlite
*.db

# SSL certificates (should be mounted separately)
ssl/
certs/
*.pem
*.key
*.crt