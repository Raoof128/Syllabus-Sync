{
  "$schema": "https://opencode.ai/config.json",

  // ============================================================
  // TEAM OPENCODE CONFIGURATION
  // Syllabus Sync - Macquarie University Campus Management
  // ============================================================
  //
  // Usage: export OPENCODE_CONFIG_DIR=/path/to/team-opencode-config
  // This ensures consistent behavior across all team machines.
  //
  // ============================================================

  // Agent Configuration
  // Default agent for all tasks - enforces Plan -> Patch -> Verify
  "agent": {
    "default": "repo-first",
    "model": "claude-sonnet-4-20250514",
  },

  // MCP Server Declarations
  // Each server extends OpenCode with specialized capabilities
  "mcp": {
    // Context7 - Documentation Retrieval (remote)
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    },

    // Sosumi - Apple Developer Documentation (remote)
    "sosumi": {
      "type": "remote",
      "url": "https://sosumi.ai/mcp",
      "enabled": true,
    },

    // Git Operations (local)
    "git": {
      "type": "local",
      "command": ["npx", "-y", "mcp-git"],
      "enabled": true,
    },

    // Sequential Thinking for Complex Problem Solving (local)
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
    },

    // File System Operations (local)
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/raoof.r12"],
      "enabled": true,
    },

    // Browser MCP - Playwright-based browser automation agent
    "browser-mcp": {
      "type": "local",
      "command": [
        "python3",
        "/Users/raoof.r12/Desktop/Raouf/Agents/MY_Agents/browser_mcp_agent/mcp_server.py",
      ],
      "enabled": true,
    },

    // SAST: Static Application Security Testing
    "semgrep": {
      "type": "local",
      "command": ["uvx", "--from", "semgrep", "semgrep", "mcp"],
      "enabled": false,
      "environment": {
        "SEMGREP_RULES": "p/typescript,p/react,p/nextjs,p/security-audit,p/secrets",
      },
    },

    // Supabase - Database and Backend Operations
    "supabase": {
      "type": "local",
      "command": ["npx", "-y", "@supabase/mcp-server-supabase"],
      "enabled": false,
      "environment": {
        "SUPABASE_ACCESS_TOKEN": "{env:SUPABASE_ACCESS_TOKEN}",
      },
    },

    // Playwright - Automated Browser Testing
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false,
    },

    // Repomix - Codebase Packing for LLM Context
    "repomix": {
      "type": "local",
      "command": ["npx", "-y", "repomix", "--mcp"],
      "enabled": false,
    },
  },

  // Project-Specific Verification Commands
  // Used by repo-first agent during VERIFY phase
  "verify": {
    "lint": "npm run lint",
    "typecheck": "npm run typecheck",
    "test": "npm run test",
    "build": "npm run build",
    "secrets": "npm run check:secrets",
  },

  // Expected Verification Results (for pass/fail detection)
  "verify_expectations": {
    "lint": {
      "success_pattern": "Lint OK",
      "fail_pattern": "error",
    },
    "test": {
      "success_pattern": "passing",
      "fail_pattern": "failed",
    },
    "build": {
      "success_pattern": "Generating static pages",
      "fail_pattern": "Build failed",
    },
  },

  // File Patterns for Smart Test Selection
  "file_patterns": {
    "source": ["app/**/*.{ts,tsx}", "components/**/*.{ts,tsx}", "lib/**/*.{ts,tsx}"],
    "tests": ["tests/**/*.{test,spec}.{ts,tsx}"],
    "config": ["*.config.{ts,js,mjs}", "tsconfig.json", "package.json"],
    "docs": ["*.md", "Team_Plan/*.md", "docs/*.md"],
  },

  // Security Scan Configuration
  "security": {
    "scan_paths": ["app/", "components/", "lib/"],
    "exclude_paths": ["node_modules/", ".next/", "coverage/"],
    "severity_threshold": "medium",
  },

  // Output Formatting
  "output": {
    "diff_context_lines": 3,
    "max_file_preview_lines": 50,
    "truncate_large_outputs": true,
    "max_output_tokens": 4000,
  },

  // Session Defaults
  "session": {
    "auto_save": true,
    "history_limit": 100,
  },
}
