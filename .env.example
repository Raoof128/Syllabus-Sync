# Syllabus Sync Environment Variables
# =====================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local to git - it contains secrets!

# ===================
# SUPABASE CONFIGURATION
# ===================
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key
# Supports both formats:
#   - Legacy JWT format: starts with "eyJ..."
#   - New publishable format: starts with "sb_..."
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase service role key (SERVER-SIDE ONLY)
# SECURITY: This key bypasses Row Level Security - NEVER expose to client
# Required for: dev email auto-confirmation, admin user operations
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===================
# OPENROUTESERVICE (ORS) API
# ===================
# Used only by the campus-raster navigation mode (`/api/navigate`).
# Google mode no longer uses ORS.
# Get a free API key from: https://openrouteservice.org/dev/#/signup
#
# SECURITY: Use server-side key ONLY (not NEXT_PUBLIC_)
# The API key is proxied through /api/navigate to prevent client exposure.
ORS_API_KEY=your-ors-api-key-here

# ===================
# GOOGLE MAPS JAVASCRIPT API (REQUIRED FOR GOOGLE MODE)
# ===================
# Browser-safe key for the Google Maps JavaScript API loader.
# Enable at minimum:
#   - Maps JavaScript API
# Restrict by HTTP referrer / app origin.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Map ID used for vector maps + Advanced Markers.
# Create in Google Cloud Console > Maps Management > Map Management.
NEXT_PUBLIC_GOOGLE_MAP_ID=

# ===================
# GOOGLE ROUTES API (SERVER-SIDE ONLY)
# ===================
# Server-only key for `/api/maps/routes`.
# Enable:
#   - Routes API
# Restrict by API scope and server/network policy where possible.
GOOGLE_ROUTES_API_KEY=

# ===================
# WEATHER WIDGET (Google Weather API)
# ===================
# The weather widget uses the Google Weather API (weather.googleapis.com).
# Enable the "Weather API" in your Google Cloud project.
# Get an API key from: https://console.cloud.google.com/apis/credentials
# SECURITY: Server-side only — NOT prefixed with NEXT_PUBLIC_
GOOGLE_WEATHER_API_KEY=

# ===================
# CSP REPORTING (Optional)
# ===================
# Configure CSP violation reporting for security monitoring
# CSP_REPORT_URI=/api/csp-report
# CSP_REPORT_TO=csp-endpoint
# CSP_REPORT_WEBHOOK=https://hooks.slack.com/services/... (optional webhook for alerts)

# ===================
# OPTIONAL CONFIGURATION
# ===================

# ORS API base URL (campus-raster mode only)
# ORS_BASE_URL=https://api.openrouteservice.org/v2/directions/foot-walking/geojson

# CORS allowed origins (comma-separated, defaults to localhost)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===================
# RATE LIMITING (PRODUCTION)
# ===================
# For production deployments, use a distributed store for rate limiting.
# Without this, rate limiting will only work per-instance (not across serverless functions).
#
# Option 1: Upstash Redis (recommended for Vercel)
# Get credentials from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Option 2: Vercel KV (if using Vercel's built-in KV store)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Demo/testing-only fallback for fail-closed rate-limited routes in production.
# Avoid enabling this in real production unless you explicitly accept in-memory
# single-instance rate limiting.
# ALLOW_MEMORY_RATE_LIMIT=false

# ===================
# DEVELOPMENT CONFIGURATION
# ===================
# Developer email bypass for email confirmation (development only)
# Comma-separated list of emails that can skip email confirmation in development
# SECURITY: Only works when NODE_ENV=development AND VERCEL_ENV is not 'production'
# IMPORTANT: Never commit real email addresses - set this in your local .env.local only
# Example format (use your own test emails):
# DEV_BYPASS_EMAILS=your-test-email@example.com

# ===================
# ERROR TRACKING (SENTRY)
# ===================
# Sentry provides real-time error tracking and performance monitoring.
# Sign up at: https://sentry.io/signup/
#
# Create a Next.js project in Sentry and get these values from:
# Settings > Projects > [Your Project] > Client Keys (DSN)

# Sentry Data Source Name (public - used in client and server)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry organization slug (from your Sentry dashboard URL)
SENTRY_ORG=

# Sentry project name
SENTRY_PROJECT=

# Sentry auth token (for uploading source maps)
# Create at: https://sentry.io/settings/auth-tokens/
# Required permissions: project:releases, project:write
SENTRY_AUTH_TOKEN=

# Enable Sentry in development (optional, defaults to production only)
# SENTRY_ENABLED=true

# Optional client-side Sentry override outside production
# NEXT_PUBLIC_SENTRY_ENABLED=false

# ===================
# CSRF PROTECTION
# ===================
# Enable/disable full CSRF token validation (double-submit cookie pattern)
# Default: enabled (true). Set to "false" to disable if causing issues.
CSRF_VALIDATION_ENABLED=true

# ===================
# WEBAUTHN / PASSKEYS
# ===================
# Relying Party ID for WebAuthn (your domain without protocol/port)
# In production, set this to your domain (e.g., syllabus-sync.vercel.app)
# Falls back to request hostname if not set
WEBAUTHN_RP_ID=localhost

# Expected origin for WebAuthn credential verification
# In production, set this to your full origin (e.g., https://syllabus-sync.vercel.app)
# Falls back to request origin if not set
WEBAUTHN_ORIGIN=http://localhost:3000

# ===================
# EMAIL SERVICE (RESEND)
# ===================
# Used for email verification and notifications
# Sign up at: https://resend.com/
# Create an API key at: https://resend.com/api-keys

# Resend API key
RESEND_API_KEY=

# From email address for verification emails
# In development, use 'onboarding@resend.dev' (Resend's test address)
# In production, use your verified domain email
VERIFICATION_EMAIL_FROM=onboarding@resend.dev

# Display name for verification emails
VERIFICATION_EMAIL_NAME=Syllabus Sync

# ===================
# APP URL CONFIGURATION
# ===================
# Base URL for the app (used for email verification links, OAuth callbacks, etc.)
# In development: http://localhost:3000
# In production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional explicit site URL used by CSRF origin allowlisting
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional explicit Supabase project ref used by CSRF origin allowlisting
# NEXT_PUBLIC_SUPABASE_PROJECT_REF=your-project-ref

# ===================
# CRON AUTH (VERCEL)
# ===================
# Used to protect cron endpoints (e.g., verification token cleanup).
#
# Vercel Cron Jobs send: Authorization: Bearer <CRON_SECRET>
# Docs: https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
#
# Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# ===================
# MAP / GEOFENCE OVERRIDES (OPTIONAL)
# ===================
# Production campus-routing geofence radius in km.
# Code defaults to 5 in production and 50 in non-production.
# GEOFENCE_BUFFER_KM=5

# ===================
# ADMIN MAP API (OPTIONAL / CONTROLLED USE)
# ===================
# Enables the admin building-position update endpoint when explicitly set to true.
# ADMIN_API_ENABLED=false
# ADMIN_SECRET_TOKEN=
