# Syllabus Sync Environment Variables
# =====================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local to git - it contains secrets!

# ===================
# SUPABASE CONFIGURATION
# ===================
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key
# Supports both formats:
#   - Legacy JWT format: starts with "eyJ..."
#   - New publishable format: starts with "sb_..."
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===================
# OPENROUTESERVICE (ORS) API
# ===================
# Used for campus map navigation/routing
# Get a free API key from: https://openrouteservice.org/dev/#/signup
#
# SECURITY: Use server-side key ONLY (not NEXT_PUBLIC_)
# The API key is proxied through /api/navigate to prevent client exposure

# Server-side ORS key (REQUIRED for navigation feature)
ORS_API_KEY=your-ors-api-key-here

# DEPRECATED: Do NOT use NEXT_PUBLIC_ORS_API_KEY
# Client-side keys are exposed in the browser and can be abused
# NEXT_PUBLIC_ORS_API_KEY is no longer supported

# ===================
# OPTIONAL CONFIGURATION
# ===================

# ORS API base URL (defaults to https://api.openrouteservice.org/v2/directions/foot-walking/geojson)
# ORS_BASE_URL=https://api.openrouteservice.org/v2/directions/foot-walking/geojson

# CORS allowed origins (comma-separated, defaults to localhost)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
