{
  "$schema": "https://opencode.ai/config.json",

  // Local OpenCode Configuration
  // MCP Servers for Apple docs, code docs, git, memory, etc.

  "mcp": {
    // Sosumi - Apple Developer Documentation (remote)
    "sosumi": {
      "type": "remote",
      "url": "https://sosumi.ai/mcp",
      "enabled": true,
    },

    // Context7 - Code Documentation Retrieval (remote)
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    },

    // Git Operations (local)
    "git": {
      "type": "local",
      "command": ["npx", "-y", "mcp-git"],
      "enabled": true,
    },

    // Sequential Thinking (local)
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
    },

    // File System (local) - needs allowed paths
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/raoof.r12"],
      "enabled": true,
    },

    // Google Maps API (HTTP transport)
    // SETUP REQUIRED:
    // 1. Get API key from https://console.cloud.google.com (enable Maps, Places, Geocoding APIs)
    // 2. Run server: npx @cablate/mcp-google-map --port 3001 --apikey "YOUR_API_KEY"
    // 3. Then enable this config
    "google-map": {
      "type": "remote",
      "url": "http://localhost:3001/mcp",
      "enabled": true,
    },

    // Claude MCP Server - Custom Rust MCP server with code intelligence
    // Features: 13+ tools, GPU embeddings, multi-workspace, semantic search
    // Source: /Users/raoof.r12/Desktop/Raouf/Research/claude-mcp-server
    "claude-mcp": {
      "type": "local",
      "command": [
        "/Users/raoof.r12/Desktop/Raouf/Research/claude-mcp-server/target/release/mcp-server",
        "--workspace",
        "/Users/raoof.r12/Desktop/Raouf/MQ_Project/syllabus-sync",
      ],
      "enabled": true,
    },

    // Browser MCP - Playwright-based browser automation agent
    "browser-mcp": {
      "type": "local",
      "command": ["python3", "/Users/raoof.r12/Desktop/Raouf/Agents/MY_Agents/browser_mcp_agent/mcp_server.py"],
      "enabled": true,
    },
  },
}
