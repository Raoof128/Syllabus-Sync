{
  "$schema": "https://json.schemastore.org/schemas/2021-06-18",
  "version": "1.0.0",
  "name": "syllabus-sync",
  "description": "Enterprise-Grade Campus Management Platform for Macquarie University",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "main": "index.js",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint --config config/eslint/eslint.config.mjs \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"features/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"data/**/*.{ts,tsx}\" \"config/eslint/eslint.config.mjs\" \"next.config.ts\" && echo \"Lint OK\"",
    "test": "vitest run --config config/vitest/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/vitest/vitest.config.ts",
    "test:watch": "vitest --config config/vitest/vitest.config.ts",
    "format": "prettier --config config/prettier/.prettierrc.json --ignore-path config/prettier/.prettierignore --write .",
    "format:check": "prettier --config config/prettier/.prettierrc.json --ignore-path config/prettier/.prettierignore --check .",
    "analyze": "ANALYZE=true npm run build",
    "test:ci": "npm run test",
    "typecheck": "tsc -p config/ts/tsconfig.json --noEmit",
    "check:secrets": "node tools/security/check-secrets.mjs",
    "check": "npm run check:secrets && npm run format:check && npm run typecheck && npm run lint && npm run test && npm run build",
    "check:i18n": "node tools/i18n/check-translations.mjs",
    "lighthouse": "lhci autorun --config=config/lighthouse/.lighthouserc.json",
    "lighthouse:local": "pkill -f 'next start' || true; npx kill-port 3000 || true; lhci collect --config-path=config/lighthouse/.lighthouserc.json",
    "docker:build": "docker build -f infra/docker/Dockerfile -t syllabus-sync .",
    "docker:run": "docker run -p 3000:3000 --env-file infra/docker/.env syllabus-sync",
    "docker:dev": "docker compose -f infra/docker/docker-compose.yml --profile development up",
    "docker:prod": "docker compose -f infra/docker/docker-compose.yml up",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "build:overlays": "echo \"Unavailable: scripts directory removed\"",
    "vercel:link": "vercel link",
    "vercel:env:pull": "vercel env pull .env.local",
    "vercel:env:check": "node tools/vercel/check-required-env.mjs",
    "vercel:deploy:preview": "node tools/vercel/deploy.mjs",
    "vercel:deploy:prod": "node tools/vercel/deploy.mjs --prod",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/nextjs": "^10.40.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "@tanstack/react-query": "^5.90.20",
    "@types/react-window": "^1.8.8",
    "@types/zxcvbn": "^4.4.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.29.0",
    "idb-keyval": "^6.2.2",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-window": "^2.2.4",
    "resend": "^6.9.2",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.9",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.1.6",
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.58.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.19.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.17",
    "autoprefixer": "^10.4.23",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001767",
    "dotenv": "^17.2.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lhci": "^4.1.1",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5",
    "vercel": "^50.28.0",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.16"
  },
  "keywords": [
    "react",
    "nextjs",
    "typescript",
    "tailwindcss",
    "supabase",
    "macquarie-university",
    "campus-management",
    "academic-calendar",
    "student-productivity",
    "gamification",
    "webauthn",
    "passkey-authentication",
    "educational-platform"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mrpouyaalavi/syllabus-sync"
  },
  "bugs": {
    "url": "https://github.com/mrpouyaalavi/syllabus-sync/issues",
    "email": "issues@syllabus-sync.dev"
  },
  "homepage": "https://syllabus-sync.dev",
  "author": "Pouya Alavi <pouya@syllabus-sync.dev>",
  "license": "MIT",
  "overrides": {
    "undici": "^7.21.0",
    "serialize-javascript": "^7.0.3",
    "path-to-regexp": "^8.3.0",
    "tar": "^7.5.9",
    "@tootallnate/once": "^3.0.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --config config/eslint/eslint.config.mjs --fix",
      "prettier --config config/prettier/.prettierrc.json --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --config config/prettier/.prettierrc.json --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
