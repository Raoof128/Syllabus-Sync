.yarn/install-state.gz

# testing
/coverage
/test-results
/playwright-report
/storybook-static

# next.js
/.next/
/.next/**
/out/

# production
/build

# misc
.DS_Store
**/.DS_Store
.npm-cache/
.ruff_cache/
.playwright-mcp/
*.pem
.eslintcache
.cache
.vite
.turbo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.tmp
*.bak
*.orig
logs/
screenshots/
artifacts/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.idea/
**/.idea/
.vscode/
