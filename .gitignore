# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# testing
/coverage
/test-results
/playwright-report
/storybook-static

# next.js
/.next/
/.next/**
/out/

# production
/build

# misc
.DS_Store
**/.DS_Store
*.pem
.eslintcache
.cache
.vite
.turbo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.tmp
*.bak
*.orig

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.idea/
**/.idea/
.vscode/
**/.vscode/
.agent/
*.swp
*.swo

# ignore exported zip artifacts
syllabus-sync_*.zip

# Supabase generated files
src/
supabase/

# Database migration scripts (local development)
database-migration.sql
fix-schema-mismatch.sql
*-migration.sql
