{
  "extends": ["@react-monorepo/eslint-config"],
  "root": true,
  "env": {
    "browser": true,
    "node": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": true,
    "tsconfigRootDir": "./",
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true,
      "modules": true
    }
  },
  "plugins": [
    "@typescript-eslint/recommended",
    "@typescript-eslint/recommended-requiring-type-checking",
    "import",
    "jsx-a11y",
    "react",
    "react-hooks",
    "@next/eslint-plugin-next",
    "@next/eslint-plugin-next/core-web-vitals"
  ],
  "rules": {
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "no-alert": "error",
    "no-var": "error",
    "prefer-const": "error",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-explicit-any": "error",
    "@typescript-eslint/no-floating-promises": "error",
    "@typescript-eslint/await-thenable": "error",
    "@typescript-eslint/prefer-nullish-coalescing": "error",
    "@typescript-eslint/no-non-null-assertion": "error",
    "@typescript-eslint/prefer-optional-chain": "error",
    "@typescript-eslint/no-unnecessary-type-assertion": "error",
    "@typescript-eslint/prefer-readonly-parameter-types": "error",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "error",
    "react/prop-types": "error",
    "react/jsx-uses-react": "error",
    "react/jsx-uses-var": "error",
    "react/self-closing-comp": "error",
    "react/jsx-uses-react-for-native-dom": "error",
    "react/no-danger": "error",
    "react/no-danger-with-children": "error",
    "react/jsx-key": "error",
    "react/no-array-index-key": "error",
    "react/no-unstable-nested-components": "error",
    "jsx-a11y/anchor-is-valid": "error",
    "jsx-a11y/alt-text": "error",
    "jsx-a11y/aria-props": "error",
    "jsx-a11y/aria-proptypes": "error",
    "jsx-a11y/aria-unsupported-elements": "error",
    "jsx-a11y/click-events-have-key-events": "error",
    "jsx-a11y/no-autofocus": "error",
    "jsx-a11y/no-static-element-interactions": "error",
    "jsx-a11y/role-has-required-aria-props": "error",
    "jsx-a11y/role-supports-aria-props": "error",
    "import/order": [
      "error",
      {
        "groups": [
          ["builtin", "external"],
          ["unknown", "unknown"],
          ["type", "object"]
        ],
        "newlines-between": "always",
        "alphabetize": {
          "order": "asc",
          "caseInsensitive": true
        }
      }
    ],
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": "node-modules",
            "pattern": ["fs", "path", "crypto", "cluster", "child_process"]
          },
          {
            "group": "dangerous-modules",
            "pattern": ["eval", "script", "vm"]
          }
        ]
      }
    ],
    "@next/next/no-page-custom-font": "error",
    "@next/next/no-img-element": "error",
    "@next/next/no-script-component": "error",
    "@next/next/no-sync-imports": "error",
    "@next/next/no-duplicate-head": "error",
    "@next/next/no-duplicate-head-in-document": "error",
    "@next/next/no-unwanted-polyfillio": "error",
    "@next/next/no-page-custom-font": ["error", { "allow": ["inter"] }],
    "@next/next/google-font-display": "error",
    "@next/next/google-font-preconnect": "error",
    "@next/next/no-typos": "error",
    "@next/next/no-css-tags": "error",
    "@next/next/no-title-in-document-head": "error",
    "@next/next/no-head-tags": "error",
    "@next/next/no-duplicate-head-in-document": "error",
    "@next/next/no-css-tags": "error",
    "@next/next/no-title-in-document-head": "error"
  },
  "overrides": [
    {
      "files": ["*.config.js", "*.config.mjs"],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "ignorePatterns": ["node_modules/**", ".next/**", "dist/**", "build/**", "coverage/**"]
}
