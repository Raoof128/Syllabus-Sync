{
  "openapi": "3.1.0",
  "info": {
    "title": "Syllabus Sync API",
    "description": "Enterprise-Grade Campus Management Platform API for Macquarie University",
    "version": "1.0.0",
    "contact": {
      "name": "API Support",
      "email": "api@syllabus-sync.dev",
      "url": "https://syllabus-sync.dev/api"
    },
    "license": {
      "name": "MIT",
      "url": "https://github.com/mrpouyaalavi/syllabus-sync/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Development server"
    },
    {
      "url": "https://syllabus-sync.dev/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/auth/session": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get current user session",
        "description": "Retrieves the current authenticated user session information",
        "operationId": "getSession",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful session retrieval",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - No valid session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Authentication"],
        "summary": "Sign out user",
        "description": "Terminates the current user session and clears authentication cookies",
        "operationId": "signOut",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully signed out",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/biometric": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Authenticate with biometric/passkey",
        "description": "Authenticate user using WebAuthn biometric authentication",
        "operationId": "authenticateBiometric",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BiometricAuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid biometric data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/units": {
      "get": {
        "tags": ["Units"],
        "summary": "Get user units",
        "description": "Retrieve all units for the authenticated user with optional filtering",
        "operationId": "getUnits",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Units retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnitsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Units"],
        "summary": "Create new unit",
        "description": "Create a new unit for the authenticated user",
        "operationId": "createUnit",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "csrfToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUnitRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Unit created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnitResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/units/{id}": {
      "get": {
        "tags": ["Units"],
        "summary": "Get specific unit",
        "description": "Retrieve a specific unit by ID",
        "operationId": "getUnit",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unit retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnitResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unit not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Units"],
        "summary": "Update unit",
        "description": "Update an existing unit",
        "operationId": "updateUnit",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "csrfToken": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUnitRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Unit updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnitResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unit not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Units"],
        "summary": "Delete unit",
        "description": "Delete a unit permanently",
        "operationId": "deleteUnit",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "csrfToken": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unit deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unit not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/deadlines": {
      "get": {
        "tags": ["Deadlines"],
        "summary": "Get user deadlines",
        "description": "Retrieve all deadlines for the authenticated user with optional filtering",
        "operationId": "getDeadlines",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          {
            "name": "completed",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "priority",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["Low", "Medium", "High", "Urgent"]
            }
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["Assignment", "Exam", "Quiz", "Presentation"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deadlines retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeadlinesResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Deadlines"],
        "summary": "Create new deadline",
        "description": "Create a new deadline for the authenticated user",
        "operationId": "createDeadline",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "csrfToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDeadlineRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Deadline created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeadlineResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/deadlines/{id}": {
      "put": {
        "tags": ["Deadlines"],
        "summary": "Update deadline",
        "description": "Update an existing deadline",
        "operationId": "updateDeadline",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "csrfToken": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDeadlineRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deadline updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeadlineResponse"
                }
              }
            }
          },
          "404": {
            "description": "Deadline not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Deadlines"],
        "summary": "Delete deadline",
        "description": "Delete a deadline permanently",
        "operationId": "deleteDeadline",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "csrfToken": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deadline deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "404": {
            "description": "Deadline not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT authentication token from Supabase"
      },
      "csrfToken": {
        "type": "apiKey",
        "in": "header",
        "name": "x-csrf-token",
        "description": "CSRF token for mutation requests"
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Operation completed successfully"
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "$ref": "#/components/schemas/Error"
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        },
        "required": ["success", "error"]
      },
      "ResponseMeta": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T12:00:00Z"
          },
          "requestId": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "VALIDATION_ERROR"
          },
          "message": {
            "type": "string",
            "example": "Invalid input data"
          },
          "details": {
            "type": "object",
            "example": {
              "field": "email",
              "message": "Invalid email format"
            }
          }
        },
        "required": ["code", "message"]
      },
      "SessionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "$ref": "#/components/schemas/User"
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "$ref": "#/components/schemas/User"
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "student@mq.edu.au"
          },
          "full_name": {
            "type": "string",
            "example": "John Doe"
          },
          "student_id": {
            "type": "string",
            "example": "12345678"
          },
          "course": {
            "type": "string",
            "example": "Bachelor of Computer Science"
          },
          "year": {
            "type": "string",
            "example": "3rd Year"
          },
          "avatar_url": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/avatar.jpg"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T12:00:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T12:00:00Z"
          }
        }
      },
      "Unit": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "code": {
            "type": "string",
            "example": "COMP2310"
          },
          "name": {
            "type": "string",
            "example": "Advanced Software Development"
          },
          "color": {
            "type": "string",
            "example": "#3B82F6"
          },
          "description": {
            "type": "string",
            "example": "Advanced software development practices and methodologies"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T12:00:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T12:00:00Z"
          }
        }
      },
      "Deadline": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "title": {
            "type": "string",
            "example": "Assignment 1 - React Components"
          },
          "description": {
            "type": "string",
            "example": "Create a comprehensive React component library with TypeScript"
          },
          "unit_code": {
            "type": "string",
            "example": "COMP2310"
          },
          "unit_id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "due_date": {
            "type": "string",
            "format": "date-time",
            "example": "2024-12-15T23:59:59Z"
          },
          "priority": {
            "type": "string",
            "enum": ["Low", "Medium", "High", "Urgent"],
            "example": "High"
          },
          "type": {
            "type": "string",
            "enum": ["Assignment", "Exam", "Quiz", "Presentation"],
            "example": "Assignment"
          },
          "completed": {
            "type": "boolean",
            "example": false
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T12:00:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T12:00:00Z"
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "building": {
            "type": "string",
            "example": "C5C"
          },
          "room": {
            "type": "string",
            "example": "204"
          }
        }
      },
      "CreateUnitRequest": {
        "type": "object",
        "required": ["code", "name"],
        "properties": {
          "code": {
            "type": "string",
            "example": "COMP2310"
          },
          "name": {
            "type": "string",
            "example": "Advanced Software Development"
          },
          "color": {
            "type": "string",
            "example": "#3B82F6"
          },
          "description": {
            "type": "string",
            "example": "Advanced software development practices"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          }
        }
      },
      "UpdateUnitRequest": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "COMP2310"
          },
          "name": {
            "type": "string",
            "example": "Updated Course Name"
          },
          "color": {
            "type": "string",
            "example": "#EF4444"
          },
          "description": {
            "type": "string",
            "example": "Updated course description"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          }
        }
      },
      "CreateDeadlineRequest": {
        "type": "object",
        "required": ["title", "unit_code", "due_date"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Assignment 1"
          },
          "description": {
            "type": "string",
            "example": "Complete the React components assignment"
          },
          "unit_code": {
            "type": "string",
            "example": "COMP2310"
          },
          "unit_id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "due_date": {
            "type": "string",
            "format": "date-time",
            "example": "2024-12-15T23:59:59Z"
          },
          "priority": {
            "type": "string",
            "enum": ["Low", "Medium", "High", "Urgent"],
            "default": "Medium"
          },
          "type": {
            "type": "string",
            "enum": ["Assignment", "Exam", "Quiz", "Presentation"],
            "default": "Assignment"
          }
        }
      },
      "UpdateDeadlineRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Updated Assignment Title"
          },
          "description": {
            "type": "string",
            "example": "Updated assignment description"
          },
          "unit_code": {
            "type": "string",
            "example": "COMP2310"
          },
          "unit_id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "due_date": {
            "type": "string",
            "format": "date-time",
            "example": "2024-12-20T23:59:59Z"
          },
          "priority": {
            "type": "string",
            "enum": ["Low", "Medium", "High", "Urgent"]
          },
          "type": {
            "type": "string",
            "enum": ["Assignment", "Exam", "Quiz", "Presentation"]
          },
          "completed": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "UnitResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "$ref": "#/components/schemas/Unit"
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        }
      },
      "DeadlineResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "$ref": "#/components/schemas/Deadline"
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        }
      },
      "UnitsResponse": {
